# ─── Shopify Storefront API ───────────────────────────────────────────────────
# Your Shopify store subdomain (e.g. my-store.myshopify.com)
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (public — safe to expose in the browser)
# Shopify Admin → Apps → Develop apps → Create app →
#   Configure Storefront API scopes → enable unauthenticated_read_products
#   → Install app → copy "Storefront API access token"
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token

# ─── Shopify Product Metafields ───────────────────────────────────────────────
# Set these up in Shopify Admin → Content → Metafields → Products
# Namespace: custom
# Keys used by the website:
#   dimensions        → text (e.g. "18\" x 10\" x 1.25\"")
#   care_instructions → text (e.g. "Hand wash only. Oil monthly.")
#   materials         → text (e.g. "Black walnut, food-safe mineral oil")
#   weight_text       → text (e.g. "2.4 lbs")
#   lead_time         → text (e.g. "3–4 weeks")
#
# Tag conventions on products:
#   Wood type: add a tag matching the wood name, e.g. "Walnut", "Oak", "Maple"
#   Size:      add a tag "Small", "Medium", or "Large"
#   Item type: set the Product Type field in Shopify (e.g. "Tables", "Cabinets", "Small Goods")

# ─── SMTP (Contact Form) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Email recipient for contact form submissions
CONTACT_TO_EMAIL=hello@haymarketwoodshop.com

# Site URL (for Open Graph tags)
NEXT_PUBLIC_SITE_URL=https://haymarketwoodshop.com
